<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="14dp">

    <!-- Top Row: Badge & Unit -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Gold capsule indicator -->
        <TextView
            android:id="@+id/widget_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BCV OFICIAL"
            android:textColor="@color/binance_gold"
            android:textSize="10sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bs/$"
            android:textColor="@color/binance_text_muted"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="6dp" />

    <!-- Center: Main Rate Value -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom">

        <TextView
            android:id="@+id/widget_rate_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="36,42"
            android:textColor="@color/binance_gold"
            android:textSize="26sp"
            android:textStyle="bold"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/widget_rate_variation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginBottom="2dp"
            android:text="▲ +0,12%"
            android:textColor="@color/binance_green"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Divider line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/binance_border" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="6dp" />

    <!-- Bottom: Cached Date -->
    <TextView
        android:id="@+id/widget_rate_date"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date text loading..."
        android:textColor="@color/binance_text_muted"
        android:textSize="9sp"
        android:singleLine="true"
        android:ellipsize="end" />

</LinearLayout>
